---
import type { Locale, Translations } from '../i18n/index';

interface Props {
  lang: Locale;
  t: Translations;
}
const { t } = Astro.props;
const basePrefix = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${basePrefix}${path.replace(/^\/+/, '')}`;

const termsUrl = 'https://drive.google.com/file/d/1J23FnOTB9ouo3kVVbwcSN7fwNPZJpXzP/view';
const links = [
  { label: t.footer.privacy, href: termsUrl, external: true },
  { label: t.footer.terms,   href: termsUrl, external: true },
  { label: t.footer.lab,     href: '#',      external: false },
];
---

<footer class="reveal" style="background:var(--color-bg-alt);border-top:1px solid var(--color-border);">
  <div style="max-width:80rem;margin:0 auto;padding:2.5rem 2rem;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1.5rem;">

    <div style="display:flex;align-items:center;gap:0.75rem;">
      <img
        src={withBase('/logo_tulumriego_sin_fondo.svg')}
        width="32"
        height="32"
        alt={t.nav.logoAlt}
        style="width:1.75rem;height:1.75rem;object-fit:contain;filter:drop-shadow(0 0 6px var(--color-primary-glow));"
      />
      <span class="font-headline" style="font-size:0.9rem;font-weight:900;letter-spacing:-0.02em;text-transform:uppercase;color:var(--color-gold);">
        {t.nav.brand}
      </span>
    </div>

    <div style="display:flex;flex-wrap:wrap;gap:1.5rem;justify-content:center;align-items:center;">
      {links.map(l => (
        <a href={l.href} class="footer-link font-headline"
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener noreferrer' : undefined}
          style="font-size:0.65rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-text-muted);text-decoration:none;transition:color .2s;">
          {l.label}
        </a>
      ))}
      <a
        href="https://agritech.ar/es"
        target="_blank"
        rel="noopener noreferrer"
        class="agritech-link font-headline"
        style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.65rem;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);text-decoration:none;transition:color .2s;"
      >
        <img
          src={withBase('/logo_agritech.png')}
          width="24"
          height="24"
          alt="Agritech Soluciones"
          style="width:1.25rem;height:1.25rem;object-fit:contain;"
        />
        <span>Powered By Agritech Soluciones</span>
      </a>
    </div>

    <p style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-text-muted);opacity:0.6;">
      {t.footer.copy}
    </p>
  </div>
</footer>

<style>
  .footer-link:hover { color: var(--color-gold) !important; }
  .agritech-link:hover { color: var(--color-primary) !important; }
</style>
