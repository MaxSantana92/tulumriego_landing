---
import type { Translations } from '../i18n/index';
import AppIcon from './AppIcon.astro';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="home" style="position:relative;min-height:90vh;display:flex;align-items:center;overflow:hidden;">
  <!-- Circuit pattern -->
  <div class="circuit-pattern" style="position:absolute;inset:0;pointer-events:none;"></div>

  <!-- Ambient glows -->
  <div style="position:absolute;top:25%;left:20%;width:500px;height:500px;border-radius:50%;background:var(--color-hero-glow);filter:blur(120px);pointer-events:none;"></div>
  <div style="position:absolute;bottom:20%;right:20%;width:380px;height:380px;border-radius:50%;background:var(--color-gold-bg);filter:blur(100px);pointer-events:none;"></div>

  <div class="asymmetric-grid" style="max-width:80rem;margin:0 auto;padding:6rem 2rem;width:100%;gap:3rem;position:relative;z-index:10;">

    <!-- LEFT: Text -->
    <div class="reveal-left active" style="display:flex;flex-direction:column;justify-content:center;gap:2rem;">

      <!-- Badge -->
      <div class="poly-cta-sm" style="display:inline-flex;align-items:center;gap:0.625rem;align-self:flex-start;padding:0.375rem 1.25rem;background:var(--color-gold-bg);border:1px solid var(--color-gold);">
        <AppIcon name="verified" size="0.875rem" style="color:var(--color-gold);" />
        <span class="font-headline" style="font-size:0.6rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">{t.hero.badge}</span>
      </div>

      <!-- H1 -->
      <h1 class="font-headline" style="font-size:clamp(2.5rem,7vw,5.5rem);font-weight:900;letter-spacing:-0.045em;line-height:0.9;color:var(--color-text);">
        {t.hero.title1}
        <span class="glow-text" style="display:block;color:var(--color-primary);">{t.hero.title2}</span>
      </h1>

      <!-- Subtitle -->
      <p style="font-size:1rem;max-width:30rem;line-height:1.7;padding-left:1.5rem;border-left:3px solid var(--color-primary);color:var(--color-text-muted);">
        {t.hero.subtitle}
      </p>

      <!-- CTAs -->
      <div style="display:flex;flex-wrap:wrap;gap:1rem;padding-top:1rem;">
        <button class="poly-cta font-headline" style="background:var(--color-primary);color:var(--color-midnight);font-size:0.85rem;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;padding:1.1rem 2rem;border:none;cursor:pointer;display:flex;align-items:center;gap:0.75rem;box-shadow:0 8px 32px var(--color-primary-glow);transition:filter .2s,transform .2s;">
          {t.hero.cta1}
          <AppIcon name="arrow_right_alt" size="1.1rem" />
        </button>
        <button class="poly-cta font-headline" style="border:2px solid var(--color-gold);color:var(--color-gold);background:var(--color-gold-bg);font-size:0.85rem;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;padding:1.1rem 2rem;cursor:pointer;transition:filter .2s,transform .2s;">
          {t.hero.cta2}
        </button>
      </div>
    </div>

    <!-- RIGHT: SVG Visual -->
    <div class="reveal-right active" style="display:flex;align-items:center;justify-content:center;position:relative;">

      <!-- Spinning rings -->
      <div style="position:absolute;width:22rem;height:22rem;border:1px solid var(--color-primary);border-radius:0;opacity:0.12;animation:spin-slow 24s linear infinite;pointer-events:none;"></div>
      <div style="position:absolute;width:17rem;height:17rem;border:1px solid var(--color-gold);opacity:0.08;animation:spin-slow 36s linear infinite reverse;pointer-events:none;"></div>

      <!-- Main SVG -->
      <div style="position:relative;z-index:20;" class="hero-visual-wrap">
        <svg viewBox="0 0 320 380" fill="none" xmlns="http://www.w3.org/2000/svg"
          style="width:min(20rem,85vw);filter:drop-shadow(0 0 50px var(--color-primary-glow));animation:float-y 5s ease-in-out infinite;">

          <!-- Outer hex -->
          <polygon points="160,10 305,92 305,278 160,370 15,278 15,92"
            stroke="currentColor" stroke-width="1" style="color:var(--color-primary);" opacity="0.25" fill="none"/>

          <!-- Inner hex -->
          <polygon points="160,50 268,112 268,258 160,320 52,258 52,112"
            stroke="currentColor" stroke-width="0.7" style="color:var(--color-primary);" opacity="0.15" fill="none"/>

          <!-- Water drop body -->
          <path d="M160 72 C127 116 98 152 98 190 C98 230 126 260 160 260 C194 260 222 230 222 190 C222 152 193 116 160 72Z"
            stroke="currentColor" stroke-width="2" style="color:var(--color-primary);"
            fill="currentColor" opacity="0.1"/>
          <path d="M160 72 C127 116 98 152 98 190 C98 230 126 260 160 260 C194 260 222 230 222 190 C222 152 193 116 160 72Z"
            stroke="currentColor" stroke-width="1.5" style="color:var(--color-primary);" fill="none"/>

          <!-- Highlight -->
          <path d="M143 122 C133 142 126 162 126 180 C126 196 134 210 145 216"
            stroke="white" stroke-width="1.5" opacity="0.22" stroke-linecap="round"/>

          <!-- Circuit stems -->
          <line x1="160" y1="260" x2="160" y2="320" stroke="currentColor" stroke-width="1" style="color:var(--color-primary);" opacity="0.35" stroke-dasharray="4 4"/>
          <line x1="98"  y1="190" x2="52"  y2="190" stroke="currentColor" stroke-width="1" style="color:var(--color-primary);" opacity="0.35" stroke-dasharray="4 4"/>
          <line x1="222" y1="190" x2="268" y2="190" stroke="currentColor" stroke-width="1" style="color:var(--color-primary);" opacity="0.35" stroke-dasharray="4 4"/>

          <!-- Nodes -->
          <circle cx="52"  cy="190" r="5" fill="currentColor" style="color:var(--color-primary);" opacity="0.9"/>
          <circle cx="268" cy="190" r="5" fill="currentColor" style="color:var(--color-primary);" opacity="0.9"/>
          <circle cx="160" cy="320" r="5" fill="currentColor" style="color:var(--color-gold);" opacity="0.9"/>

          <!-- Labels -->
          <text x="20"  y="188" font-size="8" fill="currentColor" style="color:var(--color-primary);" opacity="0.7" font-family="Space Grotesk" font-weight="700">{t.hero.visualLabels.water}</text>
          <text x="278" y="188" font-size="8" fill="currentColor" style="color:var(--color-primary);" opacity="0.7" font-family="Space Grotesk" font-weight="700">{t.hero.visualLabels.nutrients}</text>
          <text x="140" y="336" font-size="8" fill="currentColor" style="color:var(--color-gold);"   opacity="0.8" font-family="Space Grotesk" font-weight="700">{t.hero.visualLabels.ai}</text>

          <!-- Center sensor icon area -->
          <circle cx="160" cy="190" r="28" stroke="currentColor" stroke-width="1" style="color:var(--color-primary);" opacity="0.3" fill="none"/>
          <circle cx="160" cy="190" r="18" fill="currentColor" style="color:var(--color-primary);" opacity="0.12"/>
          <!-- Sensor cross -->
          <line x1="160" y1="174" x2="160" y2="206" stroke="currentColor" stroke-width="1.5" style="color:var(--color-primary);" opacity="0.7"/>
          <line x1="144" y1="190" x2="176" y2="190" stroke="currentColor" stroke-width="1.5" style="color:var(--color-primary);" opacity="0.7"/>
          <circle cx="160" cy="190" r="4" fill="currentColor" style="color:var(--color-primary);" opacity="0.9"/>

          <!-- Data ticks around drop -->
          {[0,1,2,3,4,5,6,7].map((i: number) => {
            const a = (i * 45 - 90) * Math.PI / 180;
            const x1 = 160 + 34 * Math.cos(a);
            const y1 = 190 + 34 * Math.sin(a);
            const x2 = 160 + 40 * Math.cos(a);
            const y2 = 190 + 40 * Math.sin(a);
            return <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="currentColor" stroke-width="1" style="color:var(--color-primary);" opacity="0.4"/>;
          })}
        </svg>
      </div>

      <!-- Corner accents -->
      <div style="position:absolute;right:-2rem;top:-2rem;width:7rem;height:7rem;border:1px solid var(--color-primary);opacity:0.1;rotate:12deg;pointer-events:none;"></div>
      <div style="position:absolute;left:-1.5rem;bottom:0;width:5rem;height:5rem;border:1px solid var(--color-gold);opacity:0.1;rotate:-45deg;pointer-events:none;"></div>
    </div>
  </div>

  <div class="circuit-line" style="bottom:0;"></div>
</section>

<style>
  .hero-visual-wrap:hover svg { filter: drop-shadow(0 0 70px var(--color-primary-glow)) !important; }
  button:hover { filter: brightness(1.12); transform: scale(1.03); }
</style>
