---
import type { Translations } from '../i18n/index';
import AppIcon from './AppIcon.astro';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="contact" class="reveal" style="padding:6rem 0 8rem;position:relative;">
  <div class="contact-shell" style="max-width:72rem;margin:0 auto;">

    <div class="asymmetric-grid" style="position:relative;overflow:hidden;border:1px solid var(--color-border);background:var(--color-surface-high);">

      <!-- Circuit bg -->
      <div class="circuit-pattern" style="position:absolute;inset:0;opacity:0.04;pointer-events:none;"></div>

      <!-- LEFT: Form -->
      <div class="reveal-left form-panel" style="display:flex;flex-direction:column;justify-content:center;position:relative;z-index:10;">

        <h2 class="font-headline" style="font-size:clamp(2rem,4vw,3rem);font-weight:900;letter-spacing:0.02em;line-height:1.05;text-transform:uppercase;font-style:italic;margin-bottom:1.5rem;color:var(--color-text);">
          {t.form.title1}
          <span class="glow-text" style="color:var(--color-primary);"> {t.form.title2}</span>
        </h2>

        <p style="font-size:1rem;line-height:1.7;margin-bottom:2.5rem;color:var(--color-text-muted);">
          {t.form.subtitle}
        </p>

        <form action="https://formspree.io/f/xdkwodvv" method="POST" novalidate style="display:flex;flex-direction:column;gap:1.5rem;">
          <input type="hidden" name="_subject" value="Nuevo contacto desde Tulum Riego" />

          <div class="form-inputs" style="display:grid;">
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <label class="font-headline" style="font-size:0.55rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">
                {t.form.label1}
              </label>
              <input id="contact-nombre" type="text" name="nombre" class="contact-input" autocomplete="name" placeholder={t.form.placeholder1} required minlength="2" maxlength="80" aria-describedby="error-nombre"
                style="background:var(--color-input-bg);color:var(--color-text);border:1px solid var(--color-border);padding:1rem 1.25rem;font-family:'Space Grotesk',sans-serif;font-size:0.875rem;clip-path:polygon(5% 0,100% 0,95% 100%,0 100%);" />
              <p id="error-nombre" class="field-error" data-error-for="nombre" aria-live="polite"></p>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <label class="font-headline" style="font-size:0.55rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">
                {t.form.label2}
              </label>
              <input id="contact-hectareas" type="number" name="hectareas" class="contact-input" placeholder={t.form.placeholder2} required min="0.1" step="0.1" aria-describedby="error-hectareas"
                style="background:var(--color-input-bg);color:var(--color-text);border:1px solid var(--color-border);padding:1rem 1.25rem;font-family:'Space Grotesk',sans-serif;font-size:0.875rem;clip-path:polygon(5% 0,100% 0,95% 100%,0 100%);" />
              <p id="error-hectareas" class="field-error" data-error-for="hectareas" aria-live="polite"></p>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <label class="font-headline" style="font-size:0.55rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">
                {t.form.label3}
              </label>
              <input id="contact-ubicacion" type="text" name="ubicacion" class="contact-input" autocomplete="address-level2" placeholder={t.form.placeholder3} required minlength="2" maxlength="120" aria-describedby="error-ubicacion"
                style="background:var(--color-input-bg);color:var(--color-text);border:1px solid var(--color-border);padding:1rem 1.25rem;font-family:'Space Grotesk',sans-serif;font-size:0.875rem;clip-path:polygon(5% 0,100% 0,95% 100%,0 100%);" />
              <p id="error-ubicacion" class="field-error" data-error-for="ubicacion" aria-live="polite"></p>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <label class="font-headline" style="font-size:0.55rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">
                {t.form.label4}
              </label>
              <input id="contact-email" type="email" name="email" class="contact-input" autocomplete="email" placeholder={t.form.placeholder4} required maxlength="120" aria-describedby="error-email"
                style="background:var(--color-input-bg);color:var(--color-text);border:1px solid var(--color-border);padding:1rem 1.25rem;font-family:'Space Grotesk',sans-serif;font-size:0.875rem;clip-path:polygon(5% 0,100% 0,95% 100%,0 100%);" />
              <p id="error-email" class="field-error" data-error-for="email" aria-live="polite"></p>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <label class="font-headline" style="font-size:0.55rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">
                {t.form.label5}
              </label>
              <input id="contact-telefono" type="tel" name="telefono" class="contact-input" autocomplete="tel" placeholder={t.form.placeholder5} required minlength="8" maxlength="20" pattern="^[+0-9() -]{8,20}$" aria-describedby="error-telefono"
                style="background:var(--color-input-bg);color:var(--color-text);border:1px solid var(--color-border);padding:1rem 1.25rem;font-family:'Space Grotesk',sans-serif;font-size:0.875rem;clip-path:polygon(5% 0,100% 0,95% 100%,0 100%);" />
              <p id="error-telefono" class="field-error" data-error-for="telefono" aria-live="polite"></p>
            </div>
          </div>

          <button type="submit" class="poly-cta font-headline submit-btn"
            style="background:var(--color-primary);color:var(--color-midnight);font-size:0.75rem;font-weight:900;letter-spacing:0.2em;text-transform:uppercase;padding:1.25rem;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.75rem;box-shadow:0 8px 32px var(--color-primary-glow);transition:filter .2s,transform .2s;">
            <AppIcon name="analytics" size="1.25rem" />
            {t.form.submit}
          </button>
          <p class="form-status" data-form-status aria-live="polite"></p>
        </form>
      </div>

      <!-- RIGHT: Visual -->
      <div class="reveal-right form-right" style="display:none;position:relative;min-height:26rem;align-items:flex-end;justify-content:flex-start;padding:2.5rem;">

        <!-- Gradient overlay -->
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,var(--color-bg) 0%,transparent 55%);pointer-events:none;z-index:1;"></div>

        <!-- Animated water rings -->
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0.15;pointer-events:none;">
          <svg viewBox="0 0 300 300" style="width:100%;height:100%;" fill="none">
            <circle cx="150" cy="150" r="80"  stroke="currentColor" style="color:var(--color-primary);" stroke-width="0.8" opacity="0.8" fill="none" class="ring1"/>
            <circle cx="150" cy="150" r="100" stroke="currentColor" style="color:var(--color-primary);" stroke-width="0.6" opacity="0.6" fill="none" class="ring2"/>
            <circle cx="150" cy="150" r="120" stroke="currentColor" style="color:var(--color-primary);" stroke-width="0.5" opacity="0.4" fill="none" class="ring3"/>
            <circle cx="150" cy="150" r="140" stroke="currentColor" style="color:var(--color-primary);" stroke-width="0.4" opacity="0.25" fill="none" class="ring4"/>
            <path d="M150 90 C133 110 118 130 118 150 C118 170 132 186 150 186 C168 186 182 170 182 150 C182 130 167 110 150 90Z"
              fill="currentColor" style="color:var(--color-primary);" opacity="0.35"/>
          </svg>
        </div>

        <!-- Stat cards -->
        <div class="metrics-stack" style="position:relative;z-index:10;width:100%;">
          <div class="crystalline-card metric-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
              <span class="font-headline" style="font-size:0.6rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">{t.form.impactCard2Title}</span>
              <AppIcon name="trending_up" size="1.25rem" class="glow-text" style="color:var(--color-primary);" />
            </div>
            <div class="font-headline glow-text metric-value" style="color:var(--color-text);">{t.form.impactCard2Value}</div>
            <div class="font-headline metric-label" style="color:var(--color-text-muted);">{t.form.impactCard2Desc}</div>
          </div>

          <div class="crystalline-card metric-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
              <span class="font-headline" style="font-size:0.6rem;font-weight:900;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);">{t.form.impactCard3Title}</span>
              <AppIcon name="trending_up" size="1.25rem" class="glow-text" style="color:var(--color-primary);" />
            </div>
            <div class="font-headline glow-text metric-value" style="color:var(--color-text);">{t.form.impactCard3Value}</div>
            <div class="font-headline metric-label" style="color:var(--color-text-muted);">{t.form.impactCard3Desc}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const contactForm = document.querySelector('#contact form[action*="formspree.io"]');

  if (contactForm instanceof HTMLFormElement) {
    const lang = (document.documentElement.lang || 'es').toLowerCase();
    const isEn = lang.startsWith('en');

    const messages = {
      required: isEn ? 'This field is required.' : 'Este campo es obligatorio.',
      invalidName: isEn ? 'Enter a valid name (letters and spaces only).' : 'Ingresá un nombre válido (solo letras y espacios).',
      shortName: isEn ? 'Name must have at least 2 characters.' : 'El nombre debe tener al menos 2 caracteres.',
      invalidHectares: isEn ? 'Enter a valid number of hectares greater than 0.' : 'Ingresá una cantidad de hectáreas válida mayor a 0.',
      invalidLocation: isEn ? 'Enter a valid location.' : 'Ingresá una ubicación válida.',
      shortLocation: isEn ? 'Location must have at least 2 characters.' : 'La ubicación debe tener al menos 2 caracteres.',
      invalidEmail: isEn ? 'Enter a valid email address.' : 'Ingresá un correo electrónico válido.',
      invalidPhone: isEn ? 'Enter a valid phone number (8 to 20 characters).' : 'Ingresá un teléfono válido (de 8 a 20 caracteres).',
      formErrors: isEn ? 'Please correct the highlighted fields.' : 'Corregí los campos marcados.',
      sending: isEn ? 'Sending...' : 'Enviando...',
      success: isEn ? 'Thanks! We received your contact and will get back to you soon.' : 'Gracias. Recibimos tu contacto y te responderemos pronto.',
      submitError: isEn ? 'There was an error sending the form. Please try again.' : 'Hubo un error al enviar el formulario. Intentá nuevamente.',
    };

    const statusElement = contactForm.querySelector('[data-form-status]');
    const submitButton = contactForm.querySelector('button[type="submit"]');
    const submitButtonText = submitButton?.textContent ?? '';
    const fields = ['nombre', 'hectareas', 'ubicacion', 'email', 'telefono'] as const;
    type FieldName = (typeof fields)[number];
    type StatusType = 'is-error' | 'is-success' | 'is-sending' | null;

    const getField = (name: FieldName) => contactForm.elements.namedItem(name);
    const getErrorElement = (name: FieldName) => contactForm.querySelector(`[data-error-for="${name}"]`);

    const setStatus = (message: string, type: StatusType) => {
      if (!(statusElement instanceof HTMLElement)) return;
      statusElement.textContent = message;
      statusElement.classList.remove('is-error', 'is-success', 'is-sending');
      if (type) statusElement.classList.add(type);
    };

    const clearError = (fieldName: FieldName) => {
      const input = getField(fieldName);
      const errorElement = getErrorElement(fieldName);
      if (input instanceof HTMLInputElement) {
        input.removeAttribute('aria-invalid');
        input.classList.remove('input-invalid');
      }
      if (errorElement instanceof HTMLElement) errorElement.textContent = '';
    };

    const setError = (fieldName: FieldName, message: string) => {
      const input = getField(fieldName);
      const errorElement = getErrorElement(fieldName);
      if (input instanceof HTMLInputElement) {
        input.setAttribute('aria-invalid', 'true');
        input.classList.add('input-invalid');
      }
      if (errorElement instanceof HTMLElement) errorElement.textContent = message;
    };

    const validateField = (fieldName: FieldName) => {
      clearError(fieldName);

      const input = getField(fieldName);
      if (!(input instanceof HTMLInputElement)) return true;

      const value = input.value.trim();
      if (!value) {
        setError(fieldName, messages.required);
        return false;
      }

      if (fieldName === 'nombre') {
        if (value.length < 2) {
          setError(fieldName, messages.shortName);
          return false;
        }
        if (!/^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ'’.\-\s]+$/.test(value)) {
          setError(fieldName, messages.invalidName);
          return false;
        }
      }

      if (fieldName === 'hectareas') {
        const numericValue = Number(value.replace(',', '.'));
        if (!Number.isFinite(numericValue) || numericValue <= 0) {
          setError(fieldName, messages.invalidHectares);
          return false;
        }
      }

      if (fieldName === 'ubicacion') {
        if (value.length < 2) {
          setError(fieldName, messages.shortLocation);
          return false;
        }
        if (!/^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9\s,.\-#/()]+$/.test(value)) {
          setError(fieldName, messages.invalidLocation);
          return false;
        }
      }

      if (fieldName === 'email') {
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value)) {
          setError(fieldName, messages.invalidEmail);
          return false;
        }
      }

      if (fieldName === 'telefono') {
        const digits = value.replace(/\D/g, '');
        if (!/^[+0-9() -]{8,20}$/.test(value) || digits.length < 8 || digits.length > 15) {
          setError(fieldName, messages.invalidPhone);
          return false;
        }
      }

      return true;
    };

    fields.forEach((fieldName) => {
      const input = getField(fieldName);
      if (input instanceof HTMLInputElement) {
        input.addEventListener('blur', () => validateField(fieldName));
        input.addEventListener('input', () => {
          if (input.hasAttribute('aria-invalid')) validateField(fieldName);
        });
      }
    });

    contactForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      setStatus('', null);
      const isValid = fields.every((fieldName) => validateField(fieldName));
      if (!isValid) {
        setStatus(messages.formErrors, 'is-error');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = messages.sending;
      }
      setStatus(messages.sending, 'is-sending');

      try {
        const response = await fetch(contactForm.action, {
          method: 'POST',
          body: new FormData(contactForm),
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) {
          throw new Error('Formspree response not ok');
        }

        contactForm.reset();
        fields.forEach((fieldName) => clearError(fieldName));
        setStatus(messages.success, 'is-success');
      } catch (error) {
        setStatus(messages.submitError, 'is-error');
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = submitButtonText;
        }
      }
    });
  }
</script>

<style>
  .contact-shell { padding: 0 1rem; }
  .form-panel { padding: 2rem 1.25rem; }
  .form-inputs { grid-template-columns: 1fr; gap: 1rem; }
  .form-inputs > div { min-width: 0; }
  .form-inputs input { width: 100%; }
  .field-error {
    margin: 0.2rem 0 0;
    min-height: 1rem;
    color: #ff8c8c;
    font-size: 0.72rem;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }
  .form-status {
    margin: 0;
    min-height: 1.1rem;
    font-size: 0.82rem;
    line-height: 1.3;
    color: var(--color-text-muted);
  }
  .form-status.is-error { color: #ff8c8c; }
  .form-status.is-success { color: #7ff5c7; }
  .form-status.is-sending { color: var(--color-text-muted); }
  .contact-input.input-invalid {
    border-color: #ff8c8c !important;
    box-shadow: 0 0 0 1px rgba(255, 140, 140, 0.45);
  }
  .metrics-stack { display: flex; flex-direction: column; gap: 1rem; }
  .metric-card { padding: 1.25rem; }
  .metric-value {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .metric-label {
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  @media (min-width: 768px) {
    .contact-shell { padding: 0 2rem; }
    .form-panel { padding: 3.5rem 3rem; }
    .form-right { display: flex !important; }
    .form-inputs { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .metric-card { padding: 1.5rem; }
    .metric-value { font-size: 3.75rem; }
    .metric-label { font-size: 0.52rem; }
  }
  .submit-btn:hover { filter: brightness(1.12); transform: scale(1.01); }
  .ring1 { animation: pulse-ring 2s ease-in-out infinite; }
  .ring2 { animation: pulse-ring 2.5s ease-in-out infinite; animation-delay: .3s; }
  .ring3 { animation: pulse-ring 3s ease-in-out infinite; animation-delay: .6s; }
  .ring4 { animation: pulse-ring 3.5s ease-in-out infinite; animation-delay: .9s; }
</style>
