---
import type { Locale, Translations } from '../i18n/index';
import { getLocalePath } from '../i18n/index';
import AppIcon from './AppIcon.astro';

interface Props {
  lang: Locale;
  t: Translations;
}
const { lang, t } = Astro.props;
const basePrefix = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${basePrefix}${path.replace(/^\/+/, '')}`;
const otherLang: Locale = lang === 'es' ? 'en' : 'es';
const currentLangPath = withBase(getLocalePath(lang));
const otherLangPath = withBase(getLocalePath(otherLang));

const navLinks = [
  { label: t.nav.home,       href: '#home' },
  { label: t.nav.technology, href: '#technology' },
  { label: t.nav.network,    href: '#network' },
  { label: t.nav.contact,    href: '#contact' },
];
---

<nav class="glass-nav" style="position:fixed;top:0;width:100%;z-index:50;">
  <div style="display:flex;justify-content:space-between;align-items:center;max-width:1440px;margin:0 auto;">

    <!-- Logo -->
    <a href={currentLangPath} style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
      <img
        class="logo-glow"
        src={withBase('/logo_tulumriego_sin_fondo.svg')}
        width="62"
        height="62"
        alt={t.nav.logoAlt}
        style="width:5.25rem;height:5.25rem;object-fit:contain;"
      />
      <span class="font-headline glow-text" style="font-size:1.25rem;font-weight:900;letter-spacing:-0.04em;text-transform:uppercase;color:var(--color-primary);">
        {t.nav.brand}
      </span>
    </a>

    <!-- Desktop links -->
    <div class="nav-desktop" style="display:none;align-items:center;gap:2rem;">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link font-headline"
          style="font-size:0.7rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-text-muted);text-decoration:none;transition:color .2s;">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Controls -->
    <div style="display:flex;align-items:center;gap:1rem;">

      <!-- Lang switcher -->
      <a href={otherLangPath} class="mobile-inline-control-hidden" style="display:flex;align-items:center;gap:0.375rem;font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;padding:0.375rem 0.75rem;border:1px solid var(--color-border);color:var(--color-primary);transition:border-color .2s;" title={t.nav.changeLanguage}>
        <AppIcon name="language" size="15px" />
        <span style={lang==='es' ? '' : 'opacity:0.4'}>{t.nav.langEs}</span>
        <span style="opacity:0.25;">/</span>
        <span style={lang==='en' ? '' : 'opacity:0.4'}>{t.nav.langEn}</span>
      </a>

      <!-- Theme toggle -->
      <button data-theme-toggle class="theme-toggle mobile-inline-control-hidden" aria-label={t.nav.toggleThemeAria} title={t.nav.toggleThemeTitle} aria-pressed="false">
        <span class="theme-icon theme-icon-light" aria-hidden="true">
          <AppIcon name="light_mode" size="0.85rem" />
        </span>
        <span class="theme-icon theme-icon-dark" aria-hidden="true">
          <AppIcon name="dark_mode" size="0.85rem" />
        </span>
      </button>

      <!-- CTA (desktop) -->
      <button class="nav-cta-desktop poly-cta font-headline" style="display:none;background:var(--color-primary);color:var(--color-midnight);font-size:0.65rem;font-weight:900;letter-spacing:0.2em;text-transform:uppercase;padding:0.65rem 1.75rem;border:none;cursor:pointer;transition:filter .2s,transform .2s;box-shadow:0 0 20px var(--color-primary-glow);">
        {t.nav.getStarted}
      </button>

      <!-- Hamburger -->
      <button id="mobile-menu-btn" aria-label={t.nav.openMenuAria} style="background:none;border:none;cursor:pointer;padding:0.5rem;color:var(--color-primary);display:block;">
        <AppIcon name="menu" size="1.5rem" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="border-top:1px solid var(--color-border);padding:1.5rem 2.5rem;">
    <div class="mobile-menu-controls" style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
      <a href={otherLangPath} style="display:flex;align-items:center;gap:0.375rem;font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;padding:0.375rem 0.75rem;border:1px solid var(--color-border);color:var(--color-primary);transition:border-color .2s;" title={t.nav.changeLanguage}>
        <AppIcon name="language" size="15px" />
        <span style={lang==='es' ? '' : 'opacity:0.4'}>{t.nav.langEs}</span>
        <span style="opacity:0.25;">/</span>
        <span style={lang==='en' ? '' : 'opacity:0.4'}>{t.nav.langEn}</span>
      </a>
      <button data-theme-toggle class="theme-toggle" aria-label={t.nav.toggleThemeAria} title={t.nav.toggleThemeTitle} aria-pressed="false">
        <span class="theme-icon theme-icon-light" aria-hidden="true">
          <AppIcon name="light_mode" size="0.85rem" />
        </span>
        <span class="theme-icon theme-icon-dark" aria-hidden="true">
          <AppIcon name="dark_mode" size="0.85rem" />
        </span>
      </button>
    </div>

    {navLinks.map(link => (
      <a href={link.href} class="mobile-nav-link font-headline"
        style="display:block;padding:0.75rem 0;font-size:0.8rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-text);text-decoration:none;border-bottom:1px solid var(--color-border);transition:color .2s;">
        {link.label}
      </a>
    ))}
    <button class="poly-cta font-headline" style="margin-top:1rem;width:100%;background:var(--color-primary);color:var(--color-midnight);font-size:0.7rem;font-weight:900;letter-spacing:0.2em;text-transform:uppercase;padding:0.875rem;border:none;cursor:pointer;">
      {t.nav.getStarted}
    </button>
  </div>
</nav>

<style>
  @media (min-width: 768px) {
    .nav-desktop { display: flex !important; }
    .nav-cta-desktop { display: block !important; }
    #mobile-menu-btn { display: none !important; }
    .mobile-menu-controls { display: none !important; }
  }
  @media (max-width: 767px) {
    .mobile-inline-control-hidden { display: none !important; }
  }
  .nav-link:hover, .mobile-nav-link:hover { color: var(--color-primary) !important; }
  .nav-cta-desktop:hover { filter: brightness(1.12); transform: scale(1.04); }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => menu.classList.toggle('open'));
  }

  // Anchor navigation with fixed-header offset.
  const nav = document.querySelector('nav');
  const navHeight = nav ? nav.getBoundingClientRect().height : 80;

  document.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href');
      if (!href || href === '#') return;

      const target = document.querySelector(href);
      if (!target) return;

      event.preventDefault();

      const offsetTop = target.getBoundingClientRect().top + window.scrollY - navHeight - 8;
      window.scrollTo({
        top: Math.max(offsetTop, 0),
        behavior: 'smooth',
      });

      if (menu && menu.classList.contains('open')) {
        menu.classList.remove('open');
      }

      window.history.replaceState(null, '', href);
    });
  });
</script>
