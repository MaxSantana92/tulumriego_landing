---
import type { Translations } from '../i18n/index';
import AppIcon from './AppIcon.astro';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section class="reveal" style="padding:6rem 0;position:relative;overflow:hidden;background:var(--color-bg-alt);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">

  <!-- Ambient pattern -->
  <div aria-hidden="true" style="position:absolute;inset:0;opacity:0.04;pointer-events:none;">
    <svg style="width:100%;height:100%;" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0,50 Q25,44 50,50 T100,50" fill="none" stroke="currentColor" stroke-width="0.15" style="color:var(--color-gold);"/>
      <path d="M0,62 Q25,56 50,62 T100,62" fill="none" stroke="currentColor" stroke-width="0.1" style="color:var(--color-primary);"/>
      <circle cx="15" cy="18" r="12" fill="none" stroke="currentColor" stroke-width="0.07" style="color:var(--color-gold);"/>
      <polygon points="85,8 97,22 85,36" fill="none" stroke="currentColor" stroke-width="0.06" style="color:var(--color-primary);"/>
    </svg>
  </div>

  <div style="max-width:80rem;margin:0 auto;padding:0 2rem;position:relative;z-index:10;">
    <div style="display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:5rem;">

      <!-- Award visual -->
      <div class="reveal-left" style="display:flex;justify-content:flex-end;">
        <div class="award-wrap" style="position:relative;">
          <!-- Rotating frame -->
          <div class="award-frame1" style="position:absolute;inset:-2rem;border:1px solid var(--color-gold);opacity:0.2;rotate:45deg;transition:rotate 1s ease;"></div>
          <div style="position:absolute;inset:-2rem;border:1px solid var(--color-primary);opacity:0.1;rotate:-12deg;"></div>
          <!-- Glow -->
          <div style="position:absolute;inset:0;border-radius:50%;background:var(--color-gold);opacity:0.12;filter:blur(80px);transform:scale(0.8);pointer-events:none;"></div>

          <img
            src="/LOGO_FINALISTA_COLOR_SVG.svg"
            width="200"
            height="220"
            alt={t.recognition.altImage}
            class="award-logo"
            style="width:min(18rem,80vw);position:relative;z-index:10;filter:drop-shadow(0 0 40px var(--color-gold-glow));transition:transform .5s;"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="reveal-right" style="display:flex;flex-direction:column;gap:1.5rem;">

        <div class="poly-cta-sm" style="display:inline-flex;align-items:center;gap:0.75rem;align-self:flex-start;padding:0.375rem 1rem;background:var(--color-gold-bg);border:1px solid var(--color-gold);">
          <AppIcon name="military_tech" size="1.5rem" style="color:var(--color-gold);" />
          <span class="font-headline" style="font-size:0.6rem;font-weight:900;letter-spacing:0.25em;text-transform:uppercase;color:var(--color-gold);">{t.recognition.badge}</span>
        </div>

        <h2 class="font-headline" style="font-size:clamp(2rem,4.5vw,3.5rem);font-weight:900;letter-spacing:-0.04em;line-height:1;text-transform:uppercase;color:var(--color-text);">
          {t.recognition.title1}
          <span style="display:block;font-size:0.55em;margin-top:0.4em;letter-spacing:-0.01em;word-spacing:0.12em;color:var(--color-text-muted);">{t.recognition.title2}</span>
          <span class="glow-text-gold" style="color:var(--color-gold);">{t.recognition.title3}</span>
        </h2>

        <div style="width:5rem;height:3px;background:var(--color-gold);box-shadow:var(--shadow-gold);"></div>

        <p class="font-headline" style="display:inline-block;font-size:0.6rem;font-weight:900;letter-spacing:0.25em;text-transform:uppercase;color:var(--color-gold);padding:0.375rem 0.75rem;background:var(--color-gold-bg);border-left:3px solid var(--color-gold);">
          {t.recognition.category}
        </p>

        <p style="font-size:0.95rem;line-height:1.75;color:var(--color-text-muted);padding:1.25rem;background:var(--color-surface-low);border-left:2px solid var(--color-gold);">
          {t.recognition.descriptionParts.intro}
          <strong style="color:var(--color-text);">{t.recognition.descriptionParts.institution1}</strong>
          {t.recognition.descriptionParts.middle}
          <strong style="color:var(--color-text);">{t.recognition.descriptionParts.institution2}</strong>
          {t.recognition.descriptionParts.outro}
        </p>

        <p style="font-size:0.9rem;line-height:1.75;color:var(--color-text-muted);padding:1rem 1.25rem;background:var(--color-surface-low);border-left:2px solid var(--color-border);">
          {t.recognition.juryDetails}
        </p>

        <div style="display:flex;align-items:center;gap:1rem;padding-top:0.5rem;">
          <div style="width:3rem;height:1px;background:var(--color-border);"></div>
          <span class="font-headline" style="font-size:0.55rem;font-weight:900;letter-spacing:0.4em;text-transform:uppercase;color:var(--color-text-muted);">{t.recognition.ecosystem}</span>
          <div style="width:3rem;height:1px;background:var(--color-border);"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Corner decoration -->
  <div style="position:absolute;bottom:-6rem;right:-6rem;width:14rem;height:14rem;background:var(--color-gold);opacity:0.04;rotate:12deg;" class="poly-cta"></div>
</section>

<style>
  @media (max-width: 768px) {
    .award-wrap { justify-content: center; }
    section > div > div { grid-template-columns: 1fr !important; }
    .reveal-right { text-align: center; }
    .reveal-right > * { align-self: center !important; }
  }
  .award-wrap:hover .award-frame1 { rotate: 90deg !important; }
  .award-wrap:hover .award-logo { transform: scale(1.04); }
</style>
