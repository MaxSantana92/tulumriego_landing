---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, type Locale } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  canonicalPath?: string;
  ogImagePath?: string;
  robots?: string;
}

const {
  title = 'Tulum Riego | Inteligencia Hídrica para el Futuro del Campo',
  description,
  lang,
  canonicalPath,
  ogImagePath = '/android-chrome-512x512.png',
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
} = Astro.props;
const currentLang: Locale = lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const basePrefix = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${basePrefix}${path.replace(/^\/+/, '')}`;
const defaultDescription =
  currentLang === 'en'
    ? 'Tulum Riego - Water intelligence. Manage your irrigation tasks on demand and with real-time data.'
    : 'Tulum Riego - Inteligencia hídrica. Gestioná tus labores de riego bajo demanda y con datos en tiempo real.';
const pageDescription = description ?? defaultDescription;
const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const defaultCanonicalPath = currentLang === 'en' ? withBase('/en/') : withBase('/');
const resolvedCanonicalPath = canonicalPath ? withBase(canonicalPath) : defaultCanonicalPath;
const canonicalUrl = new URL(resolvedCanonicalPath, siteOrigin).toString();
const esUrl = new URL(withBase('/'), siteOrigin).toString();
const enUrl = new URL(withBase('/en/'), siteOrigin).toString();
const ogImageUrl = new URL(withBase(ogImagePath), siteOrigin).toString();
const ogImageType = ogImagePath.endsWith('.png') ? 'image/png' : 'image/jpeg';
const ogImageWidth = '512';
const ogImageHeight = '512';
const ogLocale = currentLang === 'en' ? 'en_US' : 'es_ES';
const altOgLocale = currentLang === 'en' ? 'es_ES' : 'en_US';
---

<!doctype html>
<html lang={currentLang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/logo_tulumriego_sin_fondo.svg')} />
    
    <link rel="shortcut icon" href={withBase('/logo_tulumriego_sin_fondo.svg')} />
    <link rel="shortcut icon" type="image/png" sizes="32x32" href={withBase('/favicon-32x32.png')} />
    <link rel="shortcut icon" type="image/x-icon" href={withBase('/favicon.ico')} />
    <link rel="shortcut icon" type="image/png" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
    <link rel="shortcut icon" type="image/png" sizes="192x192" href={withBase('/android-chrome-192x192.png')} />
    <link rel="shortcut icon" type="image/png" sizes="512x512" href={withBase('/android-chrome-512x512.png')} />
    <meta name="theme-color" content="#0a0f1a" />
    
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tulum Riego" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={altOgLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <title>{title}</title>
    <link rel="preload" href={withBase('/fonts/space-grotesk-latin.woff2')} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={withBase('/fonts/plus-jakarta-sans-latin.woff2')} as="font" type="font/woff2" crossorigin />

    <!-- Anti-FOUC theme script — runs synchronously before paint -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('tulum-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'light' || (!stored && !prefersDark)) {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <!-- Subtle noise texture overlay -->
    <div aria-hidden="true" style="
      position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image: url(data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAADIAAAAyCAMAAAAp4XiDAAAAUVBMVEWFhYWDg4N3d3dtbW17e3t1dXVדדד);
      opacity: 0.018; mix-blend-mode: overlay;
    "></div>

    <Nav lang={currentLang} t={t} />

    <main style="position: relative; z-index: 10; padding-top: 5rem;">
      <slot />
    </main>

    <Footer lang={currentLang} t={t} />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .stagger-container')
        .forEach(el => observer.observe(el));
    </script>

    <!-- Theme toggle -->
    <script>
      function syncThemeToggleState() {
        const isDark = document.documentElement.classList.contains('dark');
        document.querySelectorAll('[data-theme-toggle]').forEach(btn => {
          btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
        });
      }

      function applyTheme(dark: boolean) {
        document.documentElement.classList.toggle('dark', dark);
        try { localStorage.setItem('tulum-theme', dark ? 'dark' : 'light'); } catch(e) {}
        syncThemeToggleState();
      }

      syncThemeToggleState();

      document.querySelectorAll('[data-theme-toggle]').forEach(btn => {
        btn.addEventListener('click', () => {
          applyTheme(!document.documentElement.classList.contains('dark'));
        });
      });
    </script>
  </body>
</html>
